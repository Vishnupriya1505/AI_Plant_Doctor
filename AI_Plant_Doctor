    {
      "cell_type": "code",
      "source": [
        "import tensorflow as tf\n",
        "\n",
        "def filter_classes(image, label):\n",
        "    return label < 5   # keep only first 5 classes\n",
        "\n",
        "small_dataset = dataset['train'].filter(filter_classes)"
      ],
      "metadata": {
        "id": "ew3UGZk9gUQq"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def preprocess(image, label):\n",
        "    image = tf.image.resize(image, (224, 224))\n",
        "    image = image / 255.0\n",
        "    return image, label\n",
        "\n",
        "small_dataset = small_dataset.map(preprocess)"
      ],
      "metadata": {
        "id": "B-KXBE2vhcCm"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "NUM_CLASSES = 5\n",
        "\n",
        "def encode(image, label):\n",
        "    label = tf.one_hot(label, NUM_CLASSES)\n",
        "    return image, label\n",
        "\n",
        "small_dataset = small_dataset.map(encode)"
      ],
      "metadata": {
        "id": "Qsh76_6Ghf3_"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "small_dataset = small_dataset.shuffle(1000)\n",
        "\n",
        "train_size = int(0.8 * 1000)\n",
        "\n",
        "train_data = small_dataset.take(train_size)\n",
        "val_data = small_dataset.skip(train_size)\n",
        "\n",
        "train_data = train_data.batch(32)\n",
        "val_data = val_data.batch(32)"
      ],
      "metadata": {
        "id": "8ivAWu-Xh_pL"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from tensorflow.keras.applications import MobileNetV2\n",
        "from tensorflow.keras import layers, models"
      ],
      "metadata": {
        "id": "_ZBwfjlaiVFs"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "base_model = MobileNetV2(\n",
        "    input_shape=(224, 224, 3),\n",
        "    include_top=False,\n",
        "    weights='imagenet'\n",
        ")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "I1KY-xbpjp9i",
        "outputId": "e9674835-ee6c-4363-f62f-a117f6658c5d"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Downloading data from https://storage.googleapis.com/tensorflow/keras-applications/mobilenet_v2/mobilenet_v2_weights_tf_dim_ordering_tf_kernels_1.0_224_no_top.h5\n",
            "\u001b[1m9406464/9406464\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 0us/step\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "base_model.trainable = False"
      ],
      "metadata": {
        "id": "PkOgeTKcjuU1"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "model = models.Sequential([\n",
        "    base_model,\n",
        "    layers.GlobalAveragePooling2D(),\n",
        "    layers.Dense(128, activation='relu'),\n",
        "    layers.Dropout(0.3),\n",
        "    layers.Dense(5, activation='softmax')  # 5 classes\n",
        "])"
      ],
      "metadata": {
        "id": "IC-FUQJIj3PL"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "model.compile(\n",
        "    optimizer='adam',\n",
        "    loss='categorical_crossentropy',\n",
        "    metrics=['accuracy']\n",
        ")"
      ],
      "metadata": {
        "id": "H4PqVn9vj6EY"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "history = model.fit(\n",
        "    train_data,\n",
