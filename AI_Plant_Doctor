python
AI PLANT DOCTOR PROJECT

1. Import Required Libraries
import tensorflow as tf                     # Deep learning framework
import tensorflow_datasets as tfds         # Prebuilt datasets (PlantVillage)
import numpy as np                         # Numerical operations
from tensorflow.keras.applications import MobileNetV2  # Pretrained model
from tensorflow.keras import layers, models
from tensorflow.keras.preprocessing import image       # Image processing
from google.colab import files            # Upload files in Colab

2. Load Dataset (PlantVillage)
# Loads dataset with (image, label) format
dataset, info = tfds.load("plant_village", with_info=True, as_supervised=True)

3. Select Only Required Classes
# We only use Potato + Tomato classes (6 total)
selected_classes = [14, 15, 16, 17, 18, 19]

# Filter dataset to keep only selected classes
def filter_classes(image, label):
    return tf.reduce_any(tf.equal(label, selected_classes))

small_dataset = dataset['train'].filter(filter_classes)

4. Map Labels to New Values
# Original labels are like 14,15,... → convert to 0,1,2...
keys = tf.constant(selected_classes)
values = tf.constant([0, 1, 2, 3, 4, 5])
# Lookup table for label conversion
table = tf.lookup.StaticHashTable(
    tf.lookup.KeyValueTensorInitializer(keys, values),
    default_value=-1
)

5. Preprocess Dataset
def preprocess(image, label):
    # Resize all images to 224x224 (required for MobileNet)
    image = tf.image.resize(image, (224, 224))
    
    # Normalize pixel values (0 to 1)
    image = image / 255.0
    
    # Convert label to integer and remap
    label = tf.cast(label, tf.int32)
    label = table.lookup(label)
    
    return image, label

# Apply preprocessing
small_dataset = small_dataset.map(preprocess)

6. Split Dataset (Train/Test)
small_dataset = small_dataset.shuffle(1000)   # Shuffle data

train_size = int(0.8 * 1000)                 # 80% for training

# Split dataset
train_data = small_dataset.take(train_size).batch(32)
val_data = small_dataset.skip(train_size).batch(32)

7. Build Model (MobileNetV2)
# Load pretrained MobileNetV2 (transfer learning)
base_model = MobileNetV2(
    input_shape=(224, 224, 3),
    include_top=False,
    weights='imagenet'
)

# Freeze base model layers (no retraining)
base_model.trainable = False

# Build custom model on top
model = models.Sequential([
    base_model,
    layers.GlobalAveragePooling2D(),   # Convert features to vector
    layers.Dense(128, activation='relu'),  # Hidden layer
    layers.Dropout(0.3),               # Prevent overfitting
    layers.Dense(6, activation='softmax')  # Output layer (6 classes)
])

8. Compile Model
model.compile(
    optimizer='adam',                              # Optimization algorithm
    loss='sparse_categorical_crossentropy',        # For integer labels
    metrics=['accuracy']                           # Track accuracy
)

9. Train Model
history = model.fit(
    train_data,
    validation_data=val_data,
    epochs=5     # You can increase for better accuracy
)

10. Evaluate Model
loss, accuracy = model.evaluate(val_data)
print("Validation Accuracy:", accuracy)

11. Save Model
model.save("plant_disease_model.h5")

12. Upload Leaf Image
# Opens file explorer to upload image
uploaded = files.upload()

# Get uploaded file name automatically
img_path = list(uploaded.keys())[0]

13. Load & Prepare Image
img = image.load_img(img_path, target_size=(224, 224))  # Resize
img_array = image.img_to_array(img)                     # Convert to array

# Normalize
img_array = img_array / 255.0

# Add batch dimension (required by model)
img_array = np.expand_dims(img_array, axis=0)

14. Predict Disease
prediction = model.predict(img_array)

# Get class index with highest probability
predicted_class = np.argmax(prediction)

# Class names (must match training classes)
class_names = [
    "Potato___Early_blight",
    "Potato___Late_blight",
    "Potato___healthy",
    "Tomato___Early_blight",
    "Tomato___Late_blight",
    "Tomato___healthy"
]

# Get predicted class name
name = class_names[predicted_class]

# Split into crop and disease
crop, disease = name.split("___")

# Confidence score
confidence = np.max(prediction)

15. Treatment Suggestions
treatment_dict = {
    "Potato___Early_blight": "Use fungicides and remove infected leaves.",
    "Potato___Late_blight": "Apply copper fungicide and avoid excess moisture.",
    "Potato___healthy": "Healthy plant. Maintain proper care.",
    "Tomato___Early_blight": "Use fungicides like chlorothalonil.",
    "Tomato___Late_blight": "Apply copper-based fungicide.",
    "Tomato___healthy": "Healthy plant. Maintain watering."
}

# Get treatment recommendation
treatment = treatment_dict.get(name, "No info available")

16. Display Final Result
print("\n Prediction Result")
print("Crop:", crop)
print("Disease:", disease)
print("Confidence:", round(confidence * 100, 2), "%")
print("Treatment:", treatment)
